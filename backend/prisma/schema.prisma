// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id              String   @id @default(uuid())
  instagramHandle String   @unique @db.VarChar(255)
  fullName        String?  @db.VarChar(255)
  status          String   @default("NEW") @db.VarChar(50) // NEW, CONTACTED, WARM, COLD
  priorityScore   Int      @default(0)
  aiSummary       String?  @db.Text
  
  messages        InstagramMessage[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([instagramHandle])
  @@index([status])
  @@index([priorityScore])
}

model InstagramMessage {
  id              String   @id @default(uuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  senderId        String   @db.VarChar(255) // The Instagram ID of the sender
  text            String   @db.Text
  direction       String   @db.VarChar(20) // "INBOUND" (from user) or "OUTBOUND" (from agent)
  
  timestamp       DateTime @default(now())

  @@index([leadId])
  @@index([timestamp])
}

model TelegramInteraction {
  id        String   @id @default(uuid())
  chatId    String   @db.VarChar(255)
  command   String   @db.VarChar(255)
  payload   String?  @db.Text
  status    String   @default("RECEIVED") @db.VarChar(50) // RECEIVED, PROCESSING, COMPLETED, FAILED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
}

model ContentDraft {
  id        String   @id @default(uuid())
  topic     String   @db.VarChar(255)
  content   String   @db.Text
  prompt    String?  @db.Text
  imageUrl  String?  @db.Text
  status    String   @default("PENDING_REVIEW") @db.VarChar(50) // PENDING_REVIEW, APPROVED, PUBLISHED
  platform  String   @default("INSTAGRAM") @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}
